{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with role (user or admin)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "avatarUrl": { "type": "string" }
      },
      "required": ["uid", "email", "fullName", "role", "createdAt"]
    },
    "MediaPost": {
      "title": "MediaPost",
      "description": "Media stream uploaded by the Admin (reels, video, picture, store)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["reel", "video", "picture", "store"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "price": { "type": "number" },
        "storeUrl": { "type": "string" },
        "duration": { "type": "string" },
        "likesCount": { "type": "integer" },
        "likedBy": { "type": "array", "items": { "type": "string" } },
        "sharesCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "viewsCount": { "type": "integer" },
        "contactNumber": { "type": "string" }
      },
      "required": ["id", "type", "title", "description", "mediaUrl", "likesCount", "likedBy", "sharesCount", "createdAt"]
    },
    "PostComment": {
      "title": "PostComment",
      "description": "Viewer comments on media posts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorEmail": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "postId", "authorId", "authorName", "content", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "Citizen and admin credentials profiles"
    },
    "posts/{postId}": {
      "schema": "MediaPost",
      "description": "Broadcast loops, landscape videos, snaps, and products catalog"
    },
    "comments/{commentId}": {
      "schema": "PostComment",
      "description": "Citizen comments on streams"
    }
  }
}
