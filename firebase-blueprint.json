{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "A news article posted by the admin",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the article" },
        "content": { "type": "string", "description": "Body content of the article (Markdown supported)" },
        "summary": { "type": "string", "description": "Summary of the article" },
        "category": { "type": "string", "description": "The category of the article" },
        "imageUrl": { "type": "string", "description": "Header image URL" },
        "videoUrl": { "type": "string", "description": "Optional video attachment URL" },
        "embedCode": { "type": "string", "description": "Optional media embed HTML/code" },
        "publishedAt": { "type": "string", "format": "date-time", "description": "Publication timestamp" },
        "authorId": { "type": "string", "description": "Admin UID" },
        "authorName": { "type": "string", "description": "Author display name" },
        "viewsCount": { "type": "integer", "description": "Number of views" },
        "likesCount": { "type": "integer", "description": "Number of likes" },
        "isAlert": { "type": "boolean", "description": "Whether to send as alert" },
        "waecPin": { "type": "string", "description": "Password or PIN required to view this WAEC content" }
      },
      "required": ["title", "content", "category", "publishedAt", "authorId"]
    },
    "UserPreference": {
      "title": "UserPreference",
      "description": "User personalization preferences",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User's UID" },
        "categories": { "type": "array", "description": "Interested categories" },
        "alertEnabled": { "type": "boolean", "description": "Whether notifications/alerts are enabled" },
        "savedArticles": { "type": "array", "description": "Array of saved Article IDs" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["userId", "categories"]
    },
    "ArticleLike": {
      "title": "ArticleLike",
      "description": "User liking an article",
      "type": "object",
      "properties": {
        "articleId": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["articleId", "userId", "timestamp"]
    },
    "AdminInfo": {
      "title": "AdminInfo",
      "description": "Admin credential verification helper in Firestore rules",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      },
      "required": ["email"]
    },
    "Student": {
      "title": "Student",
      "description": "A registered student profile of Dr. Abraham S. Borbor Memorial School of Excellence",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "Unique ID chosen/provided for student login" },
        "fullName": { "type": "string" },
        "gradeLevel": { "type": "string", "description": "Grade 1 to 12" },
        "password": { "type": "string" },
        "parentName": { "type": "string" },
        "phone": { "type": "string" },
        "parentPhone": { "type": "string" },
        "gender": { "type": "string" },
        "approved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "fullName", "gradeLevel", "password"]
    },
    "StudentReport": {
      "title": "StudentReport",
      "description": "Academic records, subjects with grades, and overall GPA of a student",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "gpa": { "type": "number", "description": "Calculated GPA based on Liberia High School scale" },
        "averageGrade": { "type": "number" },
        "grades": { "type": "array", "description": "List of subject names and numeric grades" },
        "term": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "grades"]
    }
  },
  "firestore": {
    "articles/{articleId}": {
      "schema": "Article",
      "description": "Collection of published news articles"
    },
    "user_preferences/{userId}": {
      "schema": "UserPreference",
      "description": "User personalization profiles"
    },
    "articles/{articleId}/likes/{likeId}": {
      "schema": "ArticleLike",
      "description": "Subcollection to track likes without race conditions"
    },
    "admins/{adminId}": {
      "schema": "AdminInfo",
      "description": "List of authorized editor admins"
    },
    "school_students/{studentId}": {
      "schema": "Student",
      "description": "Profiles of registered students"
    },
    "student_reports/{studentId}": {
      "schema": "StudentReport",
      "description": "Report cards and GPA for each student"
    }
  }
}
