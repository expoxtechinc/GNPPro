{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with role (user or admin)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "avatarUrl": { "type": "string" }
      },
      "required": ["uid", "email", "fullName", "role", "createdAt"]
    },
    "MediaPost": {
      "title": "MediaPost",
      "description": "Dynamic announcement, photo, video or calendar post for Multee Buzz, published by the Admin",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["announcement", "video", "picture", "lesson"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "duration": { "type": "string" },
        "likesCount": { "type": "integer" },
        "likedBy": { "type": "array", "items": { "type": "string" } },
        "sharesCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "viewsCount": { "type": "integer" }
      },
      "required": ["id", "type", "title", "description", "createdAt"]
    },
    "PostComment": {
      "title": "PostComment",
      "description": "Viewer comments on media posts/announcements",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorEmail": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "postId", "authorId", "authorName", "content", "createdAt"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Guest and parent contact inquiries sent to administration offices",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "resolved", "archived"] }
      },
      "required": ["fullName", "email", "subject", "message", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "Citizen and admin credentials profiles"
    },
    "posts/{postId}": {
      "schema": "MediaPost",
      "description": "School posts, announcements, campus tour videos, galleries"
    },
    "comments/{commentId}": {
      "schema": "PostComment",
      "description": "Comments on news and updates"
    },
    "inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Parent and guest submission inquiries"
    }
  }
}
