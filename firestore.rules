rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Public permissive configuration for development and sandbox preview
    match /{document=**} {
      allow read, write: if true;
    }

    // Match blocks for structured validation
    match /articles/{articleId} {
      allow read, write: if true;
      
      match /likes/{likeId} {
        allow read, write: if true;
      }
    }

    match /school_students/{studentId} {
      allow read, write: if true;
    }

    match /student_reports/{studentId} {
      allow read, write: if true;
    }

    match /school_announcements/{announceId} {
      allow read, write: if true;
    }

    match /user_preferences/{userId} {
      allow read, write: if true;
    }

    match /whatsapp_groups/{groupId} {
      allow read, write: if true;
    }

    match /advertisements/{adId} {
      allow read, write: if true;
    }

    match /admins/{adminId} {
      allow read, write: if true;
    }
  }
}
