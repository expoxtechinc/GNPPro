rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net Default-Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Users Profile Collection
    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && (
        request.auth.token.email == 'aki.sokpah.link@gmail.com' || 
        request.auth.token.email == 'luckyglobalnews@gmail.com' || 
        request.auth.token.email == 'aboysokpah@gmail.com' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Media Posts Collection (Reels, Snaps, Stores)
    match /posts/{postId} {
      allow read: if true;
      allow create, delete: if request.auth != null && (
        request.auth.token.email == 'aki.sokpah.link@gmail.com' || 
        request.auth.token.email == 'luckyglobalnews@gmail.com' || 
        request.auth.token.email == 'aboysokpah@gmail.com' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
      // Anyone can update likes count, shares count or likedBy metadata list
      allow update: if true;
    }

    // Citizen Comments on Streams
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.authorId || 
        request.auth.token.email == 'aki.sokpah.link@gmail.com' || 
        request.auth.token.email == 'luckyglobalnews@gmail.com' || 
        request.auth.token.email == 'aboysokpah@gmail.com' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // News Articles Collection (Updated dynamically by AI background triggers)
    match /articles/{articleId} {
      allow read: if true;
      allow create, update: if (
        request.auth != null && (
          request.auth.token.email == 'aki.sokpah.link@gmail.com' || 
          request.auth.token.email == 'luckyglobalnews@gmail.com' || 
          request.auth.token.email == 'aboysokpah@gmail.com' || 
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        )
      ) || (
        request.resource.data.get('systemWriteToken', '') == 'ai_editor_bot_secure_token_fe365be9'
      );
      allow delete: if (
        request.auth != null && (
          request.auth.token.email == 'aki.sokpah.link@gmail.com' || 
          request.auth.token.email == 'luckyglobalnews@gmail.com' || 
          request.auth.token.email == 'aboysokpah@gmail.com' || 
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        )
      ) || (
        resource.data.get('systemWriteToken', '') == 'ai_editor_bot_secure_token_fe365be9'
      );
    }

    // Academic Curriculum Lessons (AI/Expert course compilations)
    match /curriculum_lessons/{lessonId} {
      allow read: if true;
      allow create, update: if (
        request.auth != null && (
          request.auth.token.email == 'aki.sokpah.link@gmail.com' || 
          request.auth.token.email == 'luckyglobalnews@gmail.com' || 
          request.auth.token.email == 'aboysokpah@gmail.com' || 
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        )
      ) || (
        request.resource.data.get('systemWriteToken', '') == 'ai_editor_bot_secure_token_fe365be9'
      );
      allow delete: if (
        request.auth != null && (
          request.auth.token.email == 'aki.sokpah.link@gmail.com' || 
          request.auth.token.email == 'luckyglobalnews@gmail.com' || 
          request.auth.token.email == 'aboysokpah@gmail.com' || 
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        )
      ) || (
        resource.data.get('systemWriteToken', '') == 'ai_editor_bot_secure_token_fe365be9'
      );
    }

    // Personal user preferences and isolation
    match /user_preferences/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Admins List Collection (Locked against self-escalation)
    match /admins/{adminId} {
      allow read: if true;
      allow write: if false; // Admins cannot be self-provisioned via the client interface
    }
  }
}
