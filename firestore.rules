rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow anyone to read all collections so they can view the feeds and comments
    match /users/{userId} {
      allow read, write: if true;
    }

    match /posts/{postId} {
      allow read: if true;
      // Only the verified admin emails can create or delete posts (reels, videos, snaps, stores)
      allow create, delete: if request.auth != null && (request.auth.token.email == 'aboysokpah@gmail.com' || request.auth.token.email == 'luckyglobalnews@gmail.com');
      // Anyone can update liked list or shares count
      allow update: if true;
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
  }
}
